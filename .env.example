# ============================================================================
# CNPJ Data Lake - Configuração de Ambiente
# ============================================================================
# Copie este arquivo para .env e configure conforme seu ambiente

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=postgres_change_me
PG_OWNER_ROLE=datalake_owner
PG_USER=datalake_app
PG_PASSWORD=datalake_app_change_me
PG_DATABASE=cnpj_datalake

# ============================================================================
# MinIO Configuration
# ============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minio_root
MINIO_ROOT_PASSWORD=minio_root_change_me
MINIO_APP_ACCESS_KEY=cnpj_app_user
MINIO_APP_SECRET_KEY=cnpj_app_change_me
MINIO_ACCESS_KEY=cnpj_app_user
MINIO_SECRET_KEY=cnpj_app_change_me
MINIO_SECURE=false

# MinIO Bucket Names
MINIO_BUCKET_BRONZE=cnpj-bronze
MINIO_BUCKET_SILVER=cnpj-silver
MINIO_BUCKET_GOLD=cnpj-gold

# ============================================================================
# Data Processing
# ============================================================================
BATCH_SIZE=100000
QUALITY_THRESHOLD=90.0
DATA_VERSION=2026-03
SPARK_APP_NAME=cnpj-datalake
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
# Codificacao dos arquivos TXT de entrada da Receita. Use cp1252 se acentos aparecerem quebrados.
INPUT_FILE_ENCODING=latin1

# ============================================================================
# File Paths
# ============================================================================
PROJECT_ROOT=.
# Opcional: referencia manual para seus arquivos baixados (nao usada automaticamente no pipeline)
# SOURCE_DATA_PATH=D:\Downloads do Disco D\2026-03\2026-03

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/datalake.log

# ============================================================================
# Data Retention (days)
# ============================================================================
RETENTION_DAYS_BRONZE=90
RETENTION_DAYS_SILVER=180
RETENTION_DAYS_GOLD=-1

# ============================================================================
# Features
# ============================================================================
ENABLE_NOTIFICATIONS=true
ENABLE_PROFILING=false
ENABLE_DATA_LINEAGE=true

# ============================================================================
# Observability (Prometheus/Grafana)
# ============================================================================
METRICS_ENABLED=true
# Dentro dos containers, o endpoint deve apontar para o nome do servico Docker.
PROMETHEUS_PUSHGATEWAY_URL=http://pushgateway:9091
PROMETHEUS_JOB_NAME=cnpj_datalake_pipeline
PUSHGATEWAY_PORT=9091
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# ============================================================================
# Docker Configuration (se usar docker-compose)
# ============================================================================
COMPOSE_PROJECT_NAME=cnpj-datalake
COMPOSE_NETWORK=cnpj_network

# ============================================================================
# Airflow Configuration
# ============================================================================
AIRFLOW_UID=50000
AIRFLOW_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin_change_me
AIRFLOW_ADMIN_EMAIL=admin@local
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_change_me
AIRFLOW_FERNET_KEY=
AIRFLOW_WEBSERVER_SECRET_KEY=webserver_secret_change_me
AIRFLOW_PIPELINE_SCHEDULE=@daily
# Mes de ingestao para Airflow (formato YYYY-MM). Ex.: 2026-03
# Prioridade: Trigger DAG conf (dataset_month/data_version) > INGESTION_DATA_MONTH > INGESTION_DATA_VERSION > AIRFLOW_DATA_VERSION_OVERRIDE > DATA_VERSION > logical_date
INGESTION_DATA_MONTH=
# Paths dos arquivos de entrada dentro do container (/opt/airflow/data/input/ = data/input/ local)
# Recomendado: manter cada dataset em sua propria subpasta para evitar mistura.
# Tabelas com múltiplos arquivos usam glob (Empresas*.txt)
AIRFLOW_SOURCE_FILE_EMPRESAS=/opt/airflow/data/input/empresas/Empresas*.txt|/opt/airflow/data/input/empresas/[!.]*
AIRFLOW_SOURCE_FILE_ESTABELECIMENTOS=/opt/airflow/data/input/estabelecimentos/Estabelecimentos*.txt|/opt/airflow/data/input/estabelecimentos/[!.]*
AIRFLOW_SOURCE_FILE_SOCIOS=/opt/airflow/data/input/socios/Socios*.txt|/opt/airflow/data/input/socios/[!.]*
AIRFLOW_SOURCE_FILE_CNAES=/opt/airflow/data/input/cnaes/Cnaes.txt|/opt/airflow/data/input/cnaes/[!.]*
AIRFLOW_SOURCE_FILE_MOTIVOS=/opt/airflow/data/input/motivos/Motivos.txt|/opt/airflow/data/input/motivos/[!.]*
AIRFLOW_SOURCE_FILE_MUNICIPIOS=/opt/airflow/data/input/municipios/Municipios.txt|/opt/airflow/data/input/municipios/[!.]*
AIRFLOW_SOURCE_FILE_NATUREZAS=/opt/airflow/data/input/naturezas/Naturezas.txt|/opt/airflow/data/input/naturezas/[!.]*
AIRFLOW_SOURCE_FILE_PAISES=/opt/airflow/data/input/paises/Paises.txt|/opt/airflow/data/input/paises/[!.]*
AIRFLOW_SOURCE_FILE_QUALIFICACOES=/opt/airflow/data/input/qualificacoes/Qualificacoes.txt|/opt/airflow/data/input/qualificacoes/[!.]*

# ============================================================================
# pgAdmin Configuration
# ============================================================================
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=admin
